{
  "mcpServers": {
    "serper-search": {
      "command": "npx",
      "args": ["-y", "serper-search-mcp"],
      "env": {
        "SERPER_API_KEY": "your_serper_api_key_here/${SERPER_API_KEY}",
        "GEMINI_API_KEY": "your_gemini_api_key_here/${GEMINI_API_KEY}",
        "OPENROUTER_API_KEY": "your_openrouter_api_key_here/${OPENROUTER_API_KEY}"
      }
    }
  }
}
